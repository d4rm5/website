    let clickCount = 0;
    const hackerEl = document.getElementById('easter-egg-hacker');
    const asciiContainer = document.getElementById('ascii-container');
    const asciiText = document.getElementById('ascii-text');
    const warningPopup = document.getElementById('warning-popup');
    let isTyping = false;

    function typeWriter(text, element, callback) {
      let i = 0;
      const speed = 3;

      function type() {
        if (i < text.length) {
          element.textContent += text.charAt(i);
          i++;
          setTimeout(type, speed + Math.random() * 5);
        } else if (callback) {
          callback();
        }
      }
      type();
    }

    function startTypewriter() {
      if (!asciiContainer || !asciiText || isTyping) return;
      isTyping = true;
      asciiText.textContent = '';
      asciiContainer.classList.remove('hidden');
      typeWriter(asciiArt, asciiText, () => {
        isTyping = false;
        // ASCII stays visible until page reload
      });
    }

    function showWarning() {
      if (warningPopup) {
        warningPopup.classList.remove('hidden');
        setTimeout(() => {
          warningPopup.classList.add('hidden');
        }, 800);
      }
    }

    if (hackerEl && asciiContainer && asciiText) {
      hackerEl.addEventListener('click', () => {
        clickCount++;
        if (clickCount < 3) {
          showWarning();
        } else if (!isTyping) {
          startTypewriter();
          clickCount = 0;
        }
      });
    }
  </script>
</Base>
