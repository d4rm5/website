---
import Base from '../layouts/Base.astro';
import {
  displayName,
  events,
  formatEventRoleLabel,
  formatProfileEventDate,
  getProfileEventsChronological,
  hacktandil,
  org,
  projects,
  siteDescription,
  siteTitle,
  socials,
  tagline,
} from '../data/profile';
import AsciiArt from '../components/AsciiArt.astro';
import { asciiArt } from '../data/asciiArt';
---

<Base
  title={siteTitle}
  description={siteDescription}
  ogTitle={displayName}
  includeAgentsAlternate
>
  <div class='flex min-h-[calc(100vh-4rem)] flex-col justify-center py-8'>
    <h1 class='mb-3 text-center text-4xl font-bold text-neutral-900 sm:text-3xl dark:text-white'>
      {displayName}
    </h1>
    <p class='mb-2 text-center text-lg text-neutral-600 sm:text-base dark:text-gray-300'>
      <span id='easter-egg-hacker' class='cursor-pointer select-none hover:text-blue-600 dark:hover:text-blue-400 transition-colors'>
        {tagline}
      </span>
    </p>
    <div id='warning-popup' class='hidden fixed inset-0 z-50 flex items-center justify-center bg-black/80'>
      <div class='rounded-lg border border-red-500 bg-neutral-900 px-6 py-4 text-center shadow-xl'>
        <p class='text-red-500 font-mono text-lg'>don't click again</p>
      </div>
    </div>
<div id='ascii-container' class='hidden font-mono text-green-400 whitespace-pre leading-tight mb-4 overflow-auto'>
<span id='ascii-text' class='text-[clamp(6px,2.4vw,12px)]'></span>
    </div>
    <p class='mx-auto mb-8 max-w-lg text-center text-base text-neutral-500 sm:text-sm dark:text-gray-400'>
      Member of{' '}
      <a
        href={org.url}
        target='_blank'
        rel='noopener noreferrer'
        class='text-blue-600 hover:underline dark:text-blue-400'
        >{org.name}</a>{' '}
      and co-founder of{' '}
      <a
        href={hacktandil.url}
        target='_blank'
        rel='noopener noreferrer'
        class='text-blue-600 hover:underline dark:text-blue-400'
        >{hacktandil.name}</a>.
    </p>
    <h2 class='mb-3 mt-6 text-center text-xl font-semibold text-neutral-900 dark:text-gray-100'>Links</h2>
    <ul class='flex flex-wrap justify-center space-x-4 text-lg text-blue-600 sm:text-base dark:text-blue-400'>
      {socials.map((social) => (
        <li id={social.name}>
          <a
            href={social.url}
            class='hover:underline'
            {...(social.url.startsWith('http') || social.url.startsWith('mailto:')
              ? { target: '_blank', rel: 'noopener noreferrer' }
              : {})}
          >
            {social.name}
          </a>
        </li>
      ))}
    </ul>
    <h2 class='mb-3 mt-10 text-center text-xl font-semibold text-neutral-900 dark:text-white'>Projects</h2>
    <ul class='mx-auto mb-3 max-w-lg list-none space-y-5 text-left'>
      {projects.map((project) => (
        <li id={project.name} class='text-sm sm:text-base'>
          <a
            href={project.url}
            target='_blank'
            rel='noopener noreferrer'
            class='font-medium text-blue-600 hover:underline dark:text-blue-400'
          >
            {project.name}
          </a>
          <span class='text-neutral-600 dark:text-gray-400'> — {project.description}</span>
        </li>
      ))}
    </ul>
    {events.length > 0 ? (
      <>
        <h2 class='mb-3 mt-10 text-center text-xl font-semibold text-neutral-900 dark:text-white'>
          Talks & volunteering
        </h2>
        <ul class='mx-auto mb-3 max-w-lg list-none space-y-5 text-left'>
          {getProfileEventsChronological().map((event) => {
            const linkProps =
              event.url &&
              (event.url.startsWith('http') || event.url.startsWith('mailto:'))
                ? { target: '_blank' as const, rel: 'noopener noreferrer' as const }
                : {};
            const roleLine = event.roles.map((r) => formatEventRoleLabel(r)).join(' · ');
            const where = [formatProfileEventDate(event.date), event.location].filter(Boolean).join(' · ');
            return (
              <li id={`event-${event.name.replace(/\s+/g, '-')}`} class='text-sm sm:text-base'>
                <div>
                  {event.url ? (
                    <a
                      href={event.url}
                      class='font-medium text-blue-600 hover:underline dark:text-blue-400'
                      {...linkProps}
                    >
                      {event.name}
                    </a>
                  ) : (
                    <span class='font-medium text-neutral-900 dark:text-gray-100'>{event.name}</span>
                  )}
                  {event.detail ? (
                    <span class='text-neutral-600 dark:text-gray-400'> — {event.detail}</span>
                  ) : null}
                </div>
                <p class='mt-1 text-xs text-neutral-500 dark:text-gray-500'>
                  {roleLine}
                  {where ? ` · ${where}` : ''}
                </p>
              </li>
            );
          })}
        </ul>
      </>
    ) : null}
  </div>
  <AsciiArt text={asciiArt} />
