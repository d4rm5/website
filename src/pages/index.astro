---
import Base from '../layouts/Base.astro';
import {
  displayName,
  hacktandil,
  org,
  projects,
  siteDescription,
  siteTitle,
  socials,
  tagline,
} from '../data/profile';
---

<Base title={siteTitle} description={siteDescription} includeAgentsAlternate>
  <div class='flex min-h-[calc(100vh-4rem)] flex-col justify-center py-8'>
    <h1 class='mb-3 text-center text-4xl font-bold text-neutral-900 sm:text-3xl dark:text-white'>
      {displayName}
    </h1>
    <p class='mb-2 text-center text-lg text-neutral-600 sm:text-base dark:text-gray-300'>{tagline}</p>
    <p class='mx-auto mb-8 max-w-lg text-center text-base text-neutral-500 sm:text-sm dark:text-gray-400'>
      Member of{' '}
      <a
        href={org.url}
        target='_blank'
        rel='noopener noreferrer'
        class='text-blue-600 hover:underline dark:text-blue-400'
      >
        {org.name}
      </a>{' '}
      and co-founder of{' '}
      <a
        href={hacktandil.url}
        target='_blank'
        rel='noopener noreferrer'
        class='text-blue-600 hover:underline dark:text-blue-400'
      >
        {hacktandil.name}
      </a>.
    </p>
    <h2 class='mb-3 mt-6 text-center text-xl font-semibold text-neutral-900 dark:text-gray-100'>Links</h2>
    <ul class='flex flex-wrap justify-center space-x-4 text-lg text-blue-600 sm:text-base dark:text-blue-400'>
      {socials.map((social) => (
        <li id={social.name}>
          <a
            href={social.url}
            class='hover:underline'
            {...(social.url.startsWith('http') || social.url.startsWith('mailto:')
              ? { target: '_blank', rel: 'noopener noreferrer' }
              : {})}
          >
            {social.name}
          </a>
        </li>
      ))}
    </ul>
    <h2 class='mb-3 mt-10 text-center text-xl font-semibold text-neutral-900 dark:text-white'>Projects</h2>
    <ul class='mx-auto mb-3 max-w-lg list-none space-y-5 text-left'>
      {projects.map((project) => (
        <li id={project.name} class='text-sm sm:text-base'>
          <a
            href={project.url}
            target='_blank'
            rel='noopener noreferrer'
            class='font-medium text-blue-600 hover:underline dark:text-blue-400'
          >
            {project.name}
          </a>
          <span class='text-neutral-600 dark:text-gray-400'> — {project.description}</span>
        </li>
      ))}
    </ul>
  </div>
</Base>
