---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    const slugFromPost = (p: any) => p.slug ?? (p.id ?? '').toString().split('/').pop()?.replace(/\.[^/.]+$/, '');
    const valid = posts.filter((p: any) => !!slugFromPost(p));
    return valid.map((post: any) => ({
        params: { slug: slugFromPost(post) },
        props: { post },
    }));
}

const { post } = Astro.props;
let Content: any = null;
let hasRender = false;
let htmlFromMarkdown: string | null = null;
try {
  const rendered = await post.render();
  Content = rendered?.Content ?? null;
  hasRender = typeof Content === 'function';
} catch {
  hasRender = false;
  if (typeof post?.body === 'string' && post.body.length > 0) {
    try {
      const marked = await import('marked');
      htmlFromMarkdown = String((marked.default ?? marked).parse(post.body));
    } catch {
      htmlFromMarkdown = null;
    }
}
}

// Build a stable Markdown link ending with .md regardless of source file extension
const slugFromPost = (p: any) => p.slug ?? (p.id ?? '').toString().split('/').pop()?.replace(/\.[^/.]+$/, '');
const slugForMarkdown = slugFromPost(post);
const agentMarkdownHref = `/blog/${encodeURIComponent(slugForMarkdown)}.md`;
---

<Base
    title={`${post.data.title} · dantesito`}
    description={post.data.description}
    ogTitle={post.data.title}
    agentMarkdownHref={agentMarkdownHref}
    ogType="article"
    publishedTime={post.data.pubDate}
    ogImage={post.data.image}
>
    <nav class="mb-8 text-center text-sm text-neutral-500 dark:text-gray-500">
        <a href="/" class="hover:text-neutral-800 dark:hover:text-gray-300"
            >Home</a
        >
        <span class="mx-2">·</span>
        <a href="/blog/" class="hover:text-neutral-800 dark:hover:text-gray-300"
            >Blog</a
        >
    </nav>
    <article
        class="prose prose-sm prose-neutral mx-auto max-w-none dark:prose-invert"
    >
        <h1 class="mb-0 text-2xl font-semibold">{post.data.title}</h1>
        <p class="mt-2 text-neutral-500 not-prose dark:text-gray-500">
            {post.data.pubDate.toISOString().slice(0, 10)}
        </p>
        {
            post.data.image ? (
                <figure class="not-prose mt-8">
                    <img
                        src={post.data.image}
                        alt={post.data.title}
                        class="w-full rounded-lg border border-neutral-200 object-cover dark:border-neutral-700"
                        loading="eager"
                        decoding="async"
                        fetchpriority="high"
                    />
                </figure>
            ) : null
        }
        <div class="mt-8">
            {Content ? <Content /> : (htmlFromMarkdown ? <div set:html={htmlFromMarkdown}></div> : null)}
        </div>
    </article>
</Base>
