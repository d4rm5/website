---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const weeknotes = (await getCollection("weeknotes")).filter((weeknote) => !weeknote.data.draft);
    const slugFromWeeknote = (p: any) => p.slug ?? (p.id ?? '').toString().split('/').pop()?.replace(/\.[^/.]+$/, '');
    const valid = weeknotes.filter((p: any) => !!slugFromWeeknote(p));
    return valid.map((weeknote: any) => ({
        params: { slug: slugFromWeeknote(weeknote) },
        props: { weeknote },
    }));
}

const { weeknote } = Astro.props;
let Content: any = null;
let hasRender = false;
let htmlFromMarkdown: string | null = null;
try {
  const rendered = await render(weeknote);
  Content = rendered?.Content ?? null;
  hasRender = typeof Content === 'function';
} catch {
  hasRender = false;
  if (typeof weeknote?.body === 'string' && weeknote.body.length > 0) {
    try {
      const marked = await import('marked');
      htmlFromMarkdown = String((marked.default ?? marked).parse(weeknote.body));
    } catch {
      htmlFromMarkdown = null;
    }
}
}

// Build a stable Markdown link ending with .md regardless of source file extension
const slugFromWeeknote = (p: any) => p.slug ?? (p.id ?? '').toString().split('/').pop()?.replace(/\.[^/.]+$/, '');
const slugForMarkdown = slugFromWeeknote(weeknote);
const agentMarkdownHref = `/weeknotes/${encodeURIComponent(slugForMarkdown)}.md`;
---

<Base
    title={`${weeknote.data.title} · weeknotes · dantesito`}
    description={weeknote.data.description}
    ogTitle={weeknote.data.title}
    agentMarkdownHref={agentMarkdownHref}
    ogType="article"
    publishedTime={weeknote.data.pubDate}
    ogImage={weeknote.data.image}
>
    <nav class="mb-8 text-center text-sm text-neutral-500 dark:text-gray-500">
        <a href="/" class="hover:text-neutral-800 dark:hover:text-gray-300"
            >Home</a
        >
        <span class="mx-2">·</span>
        <a href="/blog/" class="hover:text-neutral-800 dark:hover:text-gray-300"
            >Blog</a
        >
        <span class="mx-2">·</span>
        <a
            href="/weeknotes/"
            class="hover:text-neutral-800 dark:hover:text-gray-300"
            >Weeknotes</a
        >
    </nav>
    <article
        class="prose prose-sm prose-neutral mx-auto max-w-none dark:prose-invert"
    >
        <h1 class="mb-0 text-2xl font-semibold">{weeknote.data.title}</h1>
        <p class="mt-2 text-neutral-500 not-prose dark:text-gray-500">
            {weeknote.data.pubDate.toISOString().slice(0, 10)}
        </p>
        {
            weeknote.data.image ? (
                <figure class="not-prose mt-8">
                    <img
                        src={weeknote.data.image}
                        alt={weeknote.data.title}
                        class="w-full rounded-lg border border-neutral-200 object-cover dark:border-neutral-700"
                        loading="eager"
                        decoding="async"
                        fetchpriority="high"
                    />
                </figure>
            ) : null
        }
        <div class="mt-8">
            {Content ? <Content /> : (htmlFromMarkdown ? <div set:html={htmlFromMarkdown}></div> : null)}
        </div>
    </article>
</Base>
