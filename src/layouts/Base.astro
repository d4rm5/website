---
import '@fontsource-variable/inconsolata';
import {
  siteDescription as defaultSiteDescription,
  siteTitle as defaultSiteTitle,
  twitterCreator,
  twitterSite,
} from '../data/profile';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  includeAgentsAlternate?: boolean;
  /** Raw Markdown URL for agent switch (e.g. /blog/post.md). Defaults to profile /agents.md. */
  agentMarkdownHref?: string;
  ogType?: 'website' | 'article';
  /** Absolute image URL, or path from site root (e.g. /avatar.png). Used for OG + X Cards. */
  ogImage?: string;
  /** For `og:type=article` (blog posts). */
  publishedTime?: Date;
}

const {
  title,
  description = defaultSiteDescription,
  ogTitle = defaultSiteTitle,
  includeAgentsAlternate = false,
  agentMarkdownHref = '/agents.md',
  ogType = 'website',
  ogImage: ogImageProp,
  publishedTime,
} = Astro.props;

const site = Astro.site ?? new URL('https://dantesito.com');
const canonicalUrl = new URL(Astro.url.pathname, site).href;

function absoluteImageUrl(image: string): string {
  if (image.startsWith('http://') || image.startsWith('https://')) return image;
  const path = image.startsWith('/') ? image : `/${image}`;
  return new URL(path, site).href;
}

// Use a site-wide OG image fallback for pages that don't specify one
// '/og.png' exists in the public/ folder and is suitable as a default Open Graph image.
const ogImageUrl = absoluteImageUrl(ogImageProp ?? '/og.png');
const twitterCard = ogType === 'article' ? 'summary_large_image' : 'summary';

---

<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <script is:inline>
      (function () {
        var s = localStorage.getItem('theme');
        if (s === 'light') document.documentElement.classList.remove('dark');
        else document.documentElement.classList.add('dark');
      })();
    </script>
    <link rel='icon' type='image/x-icon' href='/favicon.ico' />
    <meta name='viewport' content='width=device-width' />
    <link rel='canonical' href={canonicalUrl} />
    <link
      rel='stylesheet'
      href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css'
      integrity='sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=='
      crossorigin='anonymous'
    />
    <meta name='generator' content={Astro.generator} />
    {includeAgentsAlternate && (
      <link rel='alternate' type='text/markdown' title='Profile (Markdown for agents)' href='/agents.md' />
    )}
    {agentMarkdownHref !== '/agents.md' && (
      <link rel='alternate' type='text/markdown' title='This post as Markdown' href={agentMarkdownHref} />
    )}
    <link rel='alternate' type='application/rss+xml' title='Blog and weeknotes' href='/rss.xml' />
    <meta name='description' content={description} />
    <meta name='author' content='d4rm' />

    <meta property='og:site_name' content={defaultSiteTitle} />
    <meta property='og:title' content={ogTitle} />
    <meta property='og:description' content={description} />
    <meta property='og:url' content={canonicalUrl} />
    <meta property='og:type' content={ogType} />
    <meta property='og:locale' content='en_US' />
    <meta property='og:image' content={ogImageUrl} />
    <meta property='og:image:alt' content={ogTitle} />
    {publishedTime && (
      <meta property='article:published_time' content={publishedTime.toISOString()} />
    )}

    <meta name='twitter:card' content={twitterCard} />
    <meta name='twitter:site' content={twitterSite} />
    {ogType === 'article' && <meta name='twitter:creator' content={twitterCreator} />}
    <meta name='twitter:title' content={ogTitle} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={ogImageUrl} />

    <title>{title}</title>
    <style is:global>
      main {
        font-family: 'Inconsolata Variable', monospace;
        font-display: swap;
      }

      .x-post-embed {
        margin: 2rem auto;
        max-width: 550px;
      }

      .x-post-embed-fallback {
        margin: 0;
        border: 1px solid rgb(212 212 212);
        border-radius: 0.75rem;
        padding: 1rem;
        color: rgb(82 82 82);
        font-style: normal;
      }

      .dark .x-post-embed-fallback {
        border-color: rgb(64 64 64);
        color: rgb(212 212 212);
      }

      .x-post-embed-fallback p {
        margin: 0;
      }

      .weeknote-figure {
        margin: 2rem 0;
      }

      .weeknote-figure img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 0.5rem;
        border: 1px solid rgb(212 212 212);
      }

      .dark .weeknote-figure img {
        border-color: rgb(64 64 64);
      }

      .weeknote-figcaption {
        margin-top: 0.5rem;
        font-size: 0.8125rem;
        font-style: italic;
        line-height: 1.4;
        text-align: center;
        color: rgb(115 115 115);
      }

      .dark .weeknote-figcaption {
        color: rgb(156 163 175);
      }

      .weeknote-figcaption a {
        color: inherit;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .youtube-embed {
        aspect-ratio: 16 / 9;
        margin: 2rem 0;
        overflow: hidden;
        border: 1px solid rgb(212 212 212);
        border-radius: 0.5rem;
        background: #000;
      }

      .dark .youtube-embed {
        border-color: rgb(64 64 64);
      }

      .youtube-embed-frame {
        display: block;
        width: 100%;
        height: 100%;
        border: 0;
      }

      .bookmark-card {
        position: relative;
        isolation: isolate;
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(10.5rem, 34%);
        min-height: 10.5rem;
        margin: 2.25rem 0;
        overflow: hidden;
        border: 1px solid rgb(163 163 163 / 0.4);
        border-radius: 0.5rem;
        background:
          linear-gradient(135deg, rgb(255 255 255 / 0.96), rgb(245 245 244 / 0.82)),
          radial-gradient(circle at top left, rgb(34 197 94 / 0.12), transparent 17rem);
        box-shadow:
          0 1px 0 rgb(255 255 255 / 0.8) inset,
          0 18px 42px rgb(23 23 23 / 0.08);
        color: inherit;
        text-decoration: none;
        transform: translateZ(0);
        transition:
          border-color 180ms ease,
          box-shadow 180ms ease,
          transform 180ms ease;
      }

      .bookmark-card::before {
        content: "";
        position: absolute;
        inset: 0 auto 0 0;
        z-index: 2;
        width: 0.22rem;
        background: linear-gradient(180deg, #22c55e, #f59e0b 48%, #0ea5e9);
      }

      .bookmark-card:hover {
        border-color: rgb(82 82 82 / 0.5);
        box-shadow:
          0 1px 0 rgb(255 255 255 / 0.9) inset,
          0 22px 54px rgb(23 23 23 / 0.13);
        transform: translateY(-2px);
      }

      .dark .bookmark-card {
        border-color: rgb(115 115 115 / 0.35);
        background:
          linear-gradient(135deg, rgb(38 38 38 / 0.9), rgb(23 23 23 / 0.86)),
          radial-gradient(circle at top left, rgb(14 165 233 / 0.18), transparent 18rem);
        box-shadow:
          0 1px 0 rgb(255 255 255 / 0.08) inset,
          0 20px 48px rgb(0 0 0 / 0.3);
      }

      .dark .bookmark-card:hover {
        border-color: rgb(212 212 212 / 0.38);
        box-shadow:
          0 1px 0 rgb(255 255 255 / 0.1) inset,
          0 24px 58px rgb(0 0 0 / 0.42);
      }

      .bookmark-card-body {
        display: flex;
        min-width: 0;
        flex-direction: column;
        justify-content: center;
        gap: 0.62rem;
        padding: 1.25rem 1.35rem 1.2rem 1.55rem;
      }

      .bookmark-card-meta {
        display: flex;
        min-width: 0;
        max-width: 100%;
        align-items: center;
        gap: 0.45rem;
        color: rgb(82 82 82);
        font-size: 0.75rem;
        font-weight: 650;
        line-height: 1.2;
      }

      .dark .bookmark-card-meta {
        color: rgb(212 212 212);
      }

      .bookmark-card-favicon {
        width: 1rem;
        height: 1rem;
        flex: 0 0 auto;
        border-radius: 0.22rem;
        box-shadow: 0 0 0 1px rgb(23 23 23 / 0.08);
      }

      .dark .bookmark-card-favicon {
        box-shadow: 0 0 0 1px rgb(255 255 255 / 0.12);
      }

      .bookmark-card-site,
      .bookmark-card-url {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .bookmark-card-title {
        display: -webkit-box;
        overflow: hidden;
        color: rgb(23 23 23);
        font-size: clamp(1.12rem, 2.1vw, 1.48rem);
        font-weight: 760;
        letter-spacing: 0;
        line-height: 1.03;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
      }

      .dark .bookmark-card-title {
        color: rgb(250 250 250);
      }

      .bookmark-card-description {
        display: -webkit-box;
        overflow: hidden;
        color: rgb(64 64 64);
        font-size: 0.92rem;
        line-height: 1.32;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
      }

      .dark .bookmark-card-description {
        color: rgb(212 212 212);
      }

      .bookmark-card-url {
        color: rgb(115 115 115);
        font-size: 0.78rem;
        line-height: 1.2;
      }

      .dark .bookmark-card-url {
        color: rgb(163 163 163);
      }

      .bookmark-card-media {
        position: relative;
        display: block;
        min-height: 100%;
        overflow: hidden;
        border-left: 1px solid rgb(212 212 212 / 0.72);
        background: rgb(245 245 245);
      }

      .bookmark-card-media::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(90deg, rgb(255 255 255 / 0.18), transparent 42%),
          linear-gradient(0deg, rgb(23 23 23 / 0.14), transparent 45%);
        pointer-events: none;
      }

      .dark .bookmark-card-media {
        border-left-color: rgb(64 64 64);
        background: rgb(23 23 23);
      }

      .dark .bookmark-card-media::after {
        background:
          linear-gradient(90deg, rgb(23 23 23 / 0.3), transparent 44%),
          linear-gradient(0deg, rgb(0 0 0 / 0.18), transparent 45%);
      }

      .bookmark-card-image {
        display: block;
        width: 100%;
        height: 100%;
        min-height: 10.5rem;
        object-fit: cover;
        transition:
          filter 180ms ease,
          transform 180ms ease;
      }

      .bookmark-card:hover .bookmark-card-image {
        filter: saturate(1.08) contrast(1.03);
        transform: scale(1.035);
      }

      .bookmark-card--no-image {
        grid-template-columns: 1fr;
        min-height: 0;
      }

      @media (max-width: 640px) {
        .bookmark-card {
          grid-template-columns: 1fr;
          min-height: 0;
        }

        .bookmark-card-body {
          padding: 1.05rem 1.05rem 1.1rem 1.22rem;
        }

        .bookmark-card-media {
          order: -1;
          aspect-ratio: 1.91 / 1;
          border-bottom: 1px solid rgb(229 229 229);
          border-left: 0;
        }

        .dark .bookmark-card-media {
          border-bottom-color: rgb(64 64 64);
        }

        .bookmark-card-image {
          min-height: 0;
        }
      }
    </style>
  </head>
  <body
    class='flex min-h-screen justify-center bg-neutral-50 text-neutral-900 transition-colors dark:bg-[#1e1e1e] dark:text-white'
  >
    <div
      class='fixed right-4 top-4 z-50 flex items-center gap-0.5 rounded-lg border border-neutral-300 bg-white/95 p-0.5 shadow-sm backdrop-blur dark:border-neutral-600 dark:bg-neutral-900/95'
      role='toolbar'
      aria-label='Display options'
    >
      <button
        type='button'
        id='theme-toggle'
        class='rounded p-2 text-neutral-600 hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-800'
        aria-label='Toggle light and dark theme'
        title='Theme'
      >
        <svg
          xmlns='http://www.w3.org/2000/svg'
          fill='none'
          viewBox='0 0 24 24'
          stroke-width='1.5'
          stroke='currentColor'
          class='h-5 w-5 dark:hidden'
          aria-hidden='true'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            d='M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z'
          ></path>
        </svg>
        <svg
          xmlns='http://www.w3.org/2000/svg'
          fill='none'
          viewBox='0 0 24 24'
          stroke-width='1.5'
          stroke='currentColor'
          class='hidden h-5 w-5 dark:inline'
          aria-hidden='true'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            d='M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z'
          ></path>
        </svg>
      </button>
      <div class='mx-0.5 h-5 w-px bg-neutral-300 dark:bg-neutral-600' aria-hidden='true'></div>
      <a
        href='/'
        class='rounded bg-neutral-200 p-2 text-neutral-600 hover:bg-neutral-100 dark:bg-neutral-700 dark:text-neutral-300 dark:hover:bg-neutral-800'
        title='HTML site (human)'
      >
        <svg
          xmlns='http://www.w3.org/2000/svg'
          fill='none'
          viewBox='0 0 24 24'
          stroke-width='1.5'
          stroke='currentColor'
          class='h-5 w-5'
          aria-hidden='true'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            d='M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z'
          ></path>
        </svg>
        <span class='sr-only'>Human / HTML</span>
      </a>
      <a
        href={agentMarkdownHref}
        class='rounded p-2 text-neutral-600 hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-800'
        title={
          agentMarkdownHref === '/agents.md'
            ? 'Open profile as Markdown (/agents.md)'
            : `Open this post as Markdown (${agentMarkdownHref})`
        }
      >
        <i class='fa-solid fa-robot block w-5 text-center text-[1.05rem]' aria-hidden='true'></i>
        <span class='sr-only'>Agent / Markdown</span>
      </a>
    </div>
    <main class='mt-1 w-full max-w-screen-md px-4 pb-16 pt-14'>
      <slot />
    </main>
    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', function () {
        document.documentElement.classList.toggle('dark');
        localStorage.setItem(
          'theme',
          document.documentElement.classList.contains('dark') ? 'dark' : 'light',
        );
      });
    </script>
    <script is:inline>
      (function () {
        var embeds = document.querySelectorAll('[data-x-post-id]');
        if (embeds.length === 0) return;

        var theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
        var scriptSrc = 'https://platform.x.com/widgets.js';

        function renderEmbeds(twttr) {
          if (!twttr || !twttr.widgets || !twttr.widgets.createTweet) return;

          embeds.forEach(function (embed) {
            var renderState = embed.getAttribute('data-x-post-render-state');
            if (renderState === 'rendering' || renderState === 'rendered') return;

            var postId = embed.getAttribute('data-x-post-id');
            if (!postId) return;

            embed.setAttribute('data-x-post-render-state', 'rendering');

            var mount = embed.querySelector('.x-post-embed-mount');
            if (!mount) {
              mount = document.createElement('div');
              mount.className = 'x-post-embed-mount';
              embed.appendChild(mount);
            }
            mount.replaceChildren();

            twttr.widgets
              .createTweet(postId, mount, {
                align: 'center',
                dnt: true,
                theme: theme,
              })
              .then(function (created) {
                if (!created) {
                  embed.setAttribute('data-x-post-render-state', 'failed');
                  return;
                }
                embed.setAttribute('data-x-post-render-state', 'rendered');
                var fallback = embed.querySelector('.x-post-embed-fallback');
                if (fallback) fallback.setAttribute('hidden', '');
              })
              .catch(function () {
                embed.setAttribute('data-x-post-render-state', 'failed');
                mount.remove();
              });
          });
        }

        function onWidgetsReady() {
          if (window.twttr && window.twttr.ready) {
            window.twttr.ready(renderEmbeds);
            return;
          }

          renderEmbeds(window.twttr);
        }

        var existingScript = document.querySelector('script[src="' + scriptSrc + '"]');
        if (existingScript) {
          existingScript.addEventListener('load', onWidgetsReady, { once: true });
          onWidgetsReady();
          return;
        }

        var script = document.createElement('script');
        script.async = true;
        script.src = scriptSrc;
        script.charset = 'utf-8';
        script.addEventListener('load', onWidgetsReady, { once: true });
        document.body.appendChild(script);
      })();
    </script>
  </body>
</html>
